APP_NAME=MerrisCalzado
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erpmerris
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Fase 4.2/4.4: webhook de producto hacia ecommerceMerris.
# TODO producción: apuntar a la URL real del storefront desplegado.
ECOMMERCE_MERRIS_WEBHOOK_URL=http://127.0.0.1:8123/webhooks/erpcalzado/producto
ECOMMERCE_MERRIS_WEBHOOK_SECRET=
# Carrito Fase F (docs/PLANIFICATIONS/2026-07-11-carrito-plan.md §7): webhook
# de confirmar/anular reserva_web hacia ecommerceMerris. Mismo secreto de arriba.
ECOMMERCE_MERRIS_RESERVA_WEB_WEBHOOK_URL=http://127.0.0.1:8123/webhooks/erpcalzado/reserva-web
# Fase 3 (docs/PLANIFICATIONS/2026-07-15-plan-pendientes.md): webhook de
# estado de despacho (DESPACHADO->ENTREGADO) hacia ecommerceMerris. Mismo secreto de arriba.
ECOMMERCE_MERRIS_RESERVA_ENVIO_WEBHOOK_URL=http://127.0.0.1:8123/webhooks/erpcalzado/reserva-envio
# Token compartido para la dirección inversa: ecommerceMerris llamando a
# ErpCalzado (POST /api/reservas-web) al confirmar un pedido en checkout.
# Mismo valor que RESERVAS_WEB_API_TOKEN en .env de ecommerceMerris.
RESERVAS_WEB_API_TOKEN=

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Ruta al binario mysqldump — usado por el módulo de copias de seguridad.
MYSQLDUMP_PATH=
